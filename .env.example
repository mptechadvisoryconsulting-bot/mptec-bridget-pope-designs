ENCRYPTION_KEY=
HONEYBOOK_INTEGRATION_ENABLED=false
HONEYBOOK_INTEGRATION_SECRET=

# --- Playwright E2E tests (tests/e2e) ---
# By default, missing credentials below cause the affected E2E spec file to SKIP.
# Set E2E_RELEASE_GATE=true to instead FAIL those specs when credentials are missing —
# use this in a release/CI gate so E2E coverage can never be silently disabled.
E2E_RELEASE_GATE=false
# Owner-role login used by tests/e2e/owner-client-session.spec.ts.
E2E_OWNER_USERNAME=
E2E_OWNER_PASSWORD=
# Admin-role login used by tests/e2e/owner-client-session.spec.ts (also requires
# NEXT_PUBLIC_SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY above for test data cleanup).
E2E_ADMIN_USERNAME=
E2E_ADMIN_PASSWORD=
# Optional: override the base URL Playwright targets instead of starting a local dev server.
PLAYWRIGHT_BASE_URL=
PLAYWRIGHT_PORT=3000
