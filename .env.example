NEXT_PUBLIC_APP_URL=https://bridget-pope-designs.us
NEXT_PUBLIC_BUSINESS_NAME="Bridget Pope Designs"
NEXT_PUBLIC_BUSINESS_PHONE="(629) 295-4210"
NEXT_PUBLIC_GALLERY_BUCKET=bpd-event-gallery
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# --- Required Vercel production envs (payment release gate) ---
# PLATFORM_FEE_BASIS_POINTS must be set to 100 (1.00%) in production.
PLATFORM_FEE_BASIS_POINTS=100
# PAYMENT_CREATION_ENABLED gates online payment creation. It must stay "false" in production
# until the payment ledger migrations (0005-0008) are applied and verified — do NOT flip this
# to "true" ahead of the release gate. See LOCAL_REMEDIATION.md.
PAYMENT_CREATION_ENABLED=false
# REFUND_PLATFORM_FEE_POLICY must be set to "retain" in production (the platform fee is not
# refunded to the client when a payment is refunded).
REFUND_PLATFORM_FEE_POLICY=retain
RESEND_API_KEY=
EMAIL_FROM="Bridget Pope Designs <inquiries@example.com>"
OWNER_EMAIL=
ADMIN_EMAIL=admin@bridgetpopedesigns.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
CRON_SECRET=
ENCRYPTION_KEY=

# --- Playwright E2E tests (tests/e2e) ---
# By default, missing credentials below cause the affected E2E spec file to SKIP.
# Set E2E_RELEASE_GATE=true to instead FAIL those specs when credentials are missing —
# use this in a release/CI gate so E2E coverage can never be silently disabled.
E2E_RELEASE_GATE=false
# Owner-role login used by tests/e2e/payment-setup.spec.ts and tests/e2e/owner-client-session.spec.ts.
E2E_OWNER_USERNAME=
E2E_OWNER_PASSWORD=
# Admin-role login used by tests/e2e/owner-client-session.spec.ts (also requires
# NEXT_PUBLIC_SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY above for test data cleanup).
E2E_ADMIN_USERNAME=
E2E_ADMIN_PASSWORD=
# Optional: override the base URL Playwright targets instead of starting a local dev server.
PLAYWRIGHT_BASE_URL=
PLAYWRIGHT_PORT=3000
